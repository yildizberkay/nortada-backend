# ── Runtime ─────────────────────────────────────────────────────────────────
ENVIRONMENT=dev
PORT=3000

# ── Database (Postgres) ─────────────────────────────────────────────────────
# Local Docker Postgres (see docker-compose.yml): docker compose up -d db
DATABASE_URL=postgres://splash:splash@localhost:5432/splash

# ── Auth ────────────────────────────────────────────────────────────────────
# Our own anonymous-device JWT signing secret (HS256). Use ≥32 random chars.
AUTH_ANONYMOUS_JWT_SECRET=dev-only-anonymous-jwt-secret-change-me-32+

# Clerk (real logins — RFC-0002). Leave blank to run anonymous-only in dev.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# PEM public key → networkless token verification (prod-preferred, no per-request
# JWKS fetch). Get it from the Clerk dashboard (API keys → JWT public key).
CLERK_JWT_KEY=
# Comma-separated authorized parties (azp) — the app origins Clerk mints tokens
# for (e.g. your bundle id / frontend origin). Verified on every token.
CLERK_AUTHORIZED_PARTIES=

# ── Trigger.dev (background/cron) ───────────────────────────────────────────
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=

# ── OpenStreetMap (spot ingest — RFC-0004) ──────────────────────────────────
# Public Overpass instance. ODbL — attribute "© OpenStreetMap contributors".
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter

# ── Open-Meteo (weather — RFC-0005) ─────────────────────────────────────────
# No API key for non-commercial use. Attribute "Weather data by Open-Meteo.com".
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_MARINE_URL=https://marine-api.open-meteo.com/v1

# ── Object storage (raw GPS track blobs — RFC-0006) ─────────────────────────
# S3-compatible (AWS S3 / Cloudflare R2 / MinIO). Bucket is REQUIRED in prod
# (activity upload + metrics read both use it); leave blank in dev to run without
# it (uploads will fail clearly at the storage call). For R2/MinIO set ENDPOINT
# and FORCE_PATH_STYLE=true; REGION can be "auto" for R2.
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_FORCE_PATH_STYLE=false
