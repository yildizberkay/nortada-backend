# ── Runtime ─────────────────────────────────────────────────────────────────
ENVIRONMENT=dev
PORT=3000

# ── Database (Postgres) ─────────────────────────────────────────────────────
# Local Docker Postgres (see docker-compose.yml): docker compose up -d db
DATABASE_URL=postgres://splash:splash@localhost:5432/splash

# ── Auth ────────────────────────────────────────────────────────────────────
# Our own anonymous-device JWT signing secret (HS256). Use ≥32 random chars.
AUTH_ANONYMOUS_JWT_SECRET=dev-only-anonymous-jwt-secret-change-me-32+

# Clerk (real logins — RFC-0002). Leave blank to run anonymous-only in dev.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ── Trigger.dev (background/cron) ───────────────────────────────────────────
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=
