{
  "name": "splash-backend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint:biome": "biome check src/ scripts/ tests/",
    "lint:biome:fix": "biome check --write src/ scripts/ tests/",
    "lint:type": "tsc --noEmit --project tsconfig.check.json",
    "lint:imports": "bash scripts/check-import-direction.sh",
    "db:gen": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "env:gen": "cp .env.sample .env",
    "trigger:dev": "npx trigger.dev@latest dev",
    "test": "jest --silent",
    "test:verbose": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@clerk/backend": "^3.4.4",
    "@hono/node-server": "^2.0.1",
    "@hono/standard-validator": "^0.2.3",
    "@hono/swagger-ui": "^0.6.1",
    "@trigger.dev/sdk": "4.5.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16",
    "hono-openapi": "^1.3.0",
    "jose": "^6.1.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@jest/globals": "^30.3.0",
    "@trigger.dev/build": "4.5.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.7",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
